---
import Layout from "../layouts/Layouts.astro";
import AppModal from "../components/AppModal.jsx";
---

<Layout title="Registro">
    <AppModal client:load modalId="register-feedback" />
    <main
        style="margin: 15vh 0px; top: 0px; height: 100%; display: flex; justify-content: center;"
    >
        <form id="login">
            <div class="contenedor">
                <h1>Regístrate</h1>
                <hr />
                <label for="user">Nombre de usuario:</label>
                <input
                    type="text"
                    name="username"
                    id="username"
                    placeholder="marcoaldany002"
                />
                <div id="username-error" class="info-contain-error">
                    <p>Por favor rellena los campos</p>
                </div>
                <label for="name">Nombre:</label>
                <input type="text" name="name" id="name" />
                <div id="name-error" class="info-contain-error">
                    <p>Por favor rellena los campos</p>
                </div>
                <label for="lastname">Apellidos:</label>
                <input type="text" name="lastname" id="lastname" />
                <div id="lastname-error" class="info-contain-error">
                    <p>Por favor rellena los campos</p>
                </div>
                <label for="mail">Dirección de Correo Electrónico:</label>
                <input
                    type="email"
                    name="mail"
                    id="mail"
                    placeholder="example@domain.com"
                />
                <div id="email-error" class="info-contain-error">
                    <p>Ya esta registrado este mail</p>
                </div>
                <label for="password">Contraseña:</label>
                <input type="password" name="password" id="password" />
                <div
                    class="info-contain-error password-presets"
                    style="display: block !important;"
                >
                    <p id="password-mayus">Debe de contener alguna mayúscula</p>
                    <p id="password-number">Debe de contener algún numero</p>
                    <p id="password-sign">
                        Debe de contener algún signo -+*‚¿?!
                    </p>
                    <p id="password-max6">
                        Debe de contener minino 6 caracteres
                    </p>
                </div>
                <label for="confirmpassword">Confirmar Contraseña:</label>
                <input
                    type="password"
                    name="confirmpassword"
                    id="confirmpassword"
                />
                <div class="info-contain-error" id="password-error">
                    <p>La contraseñas no coinciden</p>
                </div>

                <input class="acpbutton" type="submit" value="Registrarme" />
                <div class="setpswdre">
                    <a href="/login" class="lwsv"
                        >Ya tengo cuenta, iniciar sesion</a
                    >
                </div>
            </div>
        </form>
    </main>
</Layout>

<script>
    import { navigate } from "astro:transitions/client";

    const openModal = (config: Record<string, unknown>) => {
        window.dispatchEvent(new CustomEvent("app-modal:open", {
            detail: {
                id: "register-feedback",
                config,
            },
        }));
    };

    const showError = (el: HTMLElement, show: boolean) => {
        el.style.display = show ? "block" : "none";
    };

    const showModal = (
        type: "success" | "error",
        title: string,
        text: string,
    ) => {
        openModal({
            kind: "message",
            type,
            title,
            text,
            buttonText: type === "success" ? "Aceptar" : "Intentar de nuevo",
            showButton: type !== "success",
            showProgress: type === "success",
            closeOnBackdrop: false,
            showCloseButton: false,
        });

        if (type === "success") {
            setTimeout(() => navigate("/login"), 4000);
        }
    };

    const setupRegisterPage = () => {
        const form = document.getElementById("login") as HTMLFormElement | null;
        if (!form || form.dataset.initialized === "true") return;

        form.dataset.initialized = "true";

        const params = new URLSearchParams(window.location.search);
        const redirectParam = params.get("redirect");
        const safeRedirect = redirectParam && redirectParam.startsWith("/")
            ? redirectParam
            : null;

        const passwordInput = document.getElementById(
            "password",
        ) as HTMLInputElement;

        const reqMayus = document.getElementById(
            "password-mayus",
        ) as HTMLParagraphElement;
        const reqNumber = document.getElementById(
            "password-number",
        ) as HTMLParagraphElement;
        const reqSign = document.getElementById(
            "password-sign",
        ) as HTMLParagraphElement;
        const reqMax6 = document.getElementById(
            "password-max6",
        ) as HTMLParagraphElement;

        const usernameError = document.getElementById(
            "username-error",
        ) as HTMLElement;
        const nameError = document.getElementById("name-error") as HTMLElement;
        const lastnameError = document.getElementById(
            "lastname-error",
        ) as HTMLElement;
        const emailError = document.getElementById("email-error") as HTMLElement;
        const passwordError = document.getElementById(
            "password-error",
        ) as HTMLElement;
        const loginLink = document.querySelector('a[href="/login"]') as HTMLAnchorElement | null;

        if (loginLink && safeRedirect) {
            loginLink.href = `/login?redirect=${encodeURIComponent(safeRedirect)}`;
        }

        const hideAll = () => {
            [
                usernameError,
                nameError,
                lastnameError,
                emailError,
                passwordError,
            ].forEach((el) => {
                el.style.display = "none";
            });
        };

        window.addEventListener("app-modal:closed", ((event: Event) => {
            const detail = (event as CustomEvent).detail;
            if (detail?.id !== "register-feedback") return;

            const btn = form.querySelector(
                "input[type=submit]",
            ) as HTMLInputElement | null;
            if (!btn) return;

            btn.value = "Registrarme";
            btn.disabled = false;
        }) as EventListener);

        passwordInput.addEventListener("input", () => {
            const val = passwordInput.value;
            const checks = [
                { el: reqMayus, ok: /[A-Z]/.test(val) },
                { el: reqNumber, ok: /[0-9]/.test(val) },
                { el: reqSign, ok: /[-+*‚¿?!]/.test(val) },
                { el: reqMax6, ok: val.length >= 6 },
            ];
            checks.forEach(({ el, ok }) => {
                el.classList.toggle("req-ok", ok);
                el.classList.toggle("req-fail", !ok);
            });
            const allOk = checks.every(({ ok }) => ok);
            const container = document.querySelector(
                ".password-presets",
            ) as HTMLElement;
            container.style.backgroundColor = allOk ? "#2ecc7117" : "#7f000017";
            container.style.borderColor = allOk ? "#2ecc7142" : "#b2000042";
        });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            hideAll();

            const username = (
                document.getElementById("username") as HTMLInputElement
            ).value.trim();
            const name = (
                document.getElementById("name") as HTMLInputElement
            ).value.trim();
            const lastname = (
                document.getElementById("lastname") as HTMLInputElement
            ).value.trim();
            const mail = (
                document.getElementById("mail") as HTMLInputElement
            ).value.trim();
            const password = passwordInput.value;
            const confirmpass = (
                document.getElementById("confirmpassword") as HTMLInputElement
            ).value;

            let hasError = false;
            if (!username) {
                showError(usernameError, true);
                hasError = true;
            }
            if (!name) {
                showError(nameError, true);
                hasError = true;
            }
            if (!lastname) {
                showError(lastnameError, true);
                hasError = true;
            }
            if (!mail) {
                showError(emailError, true);
                hasError = true;
            }
            if (password !== confirmpass) {
                showError(passwordError, true);
                hasError = true;
            }
            if (
                !/[A-Z]/.test(password) ||
                !/[0-9]/.test(password) ||
                !/[-+*‚¿?!]/.test(password) ||
                password.length < 6
            ) {
                hasError = true;
            }
            if (hasError) return;

            const btn = form.querySelector(
                "input[type=submit]",
            ) as HTMLInputElement;
            btn.value = "Enviando código...";
            btn.disabled = true;

            const res = await fetch("/api/auth/register", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    username,
                    nombre: name,
                    apellidos: lastname,
                    email: mail,
                    password,
                }),
            });
            const data = await res.json();

            btn.value = "Registrarme";
            btn.disabled = false;

            if (!res.ok) {
                if (data.error === "username_taken") {
                    usernameError.querySelector("p")!.textContent =
                        "Este nombre de usuario ya esta en uso.";
                    showError(usernameError, true);
                    return;
                }
                if (data.error === "email_taken") {
                    emailError.querySelector("p")!.textContent =
                        "Este email ya esta registrado.";
                    showError(emailError, true);
                    return;
                }
                showModal(
                    "error",
                    "No se ha podido registrar",
                    data.message || "Inténtalo mas tarde.",
                );
                return;
            }

            form.reset();

            const verifyUrl = new URL("/verify", window.location.origin);
            verifyUrl.searchParams.set("email", mail);
            if (safeRedirect) {
                verifyUrl.searchParams.set("redirect", safeRedirect);
            }
            navigate(`${verifyUrl.pathname}${verifyUrl.search}`);
        });
    };

    setupRegisterPage();
    document.addEventListener("astro:page-load", setupRegisterPage);
</script>
