---
import Layout from "../layouts/Layouts.astro";
---

<Layout title="Mi Perfil">
    <main
        style="margin: 15vh 0px; top: 0px; height: 100%; display: flex; justify-content: center;"
    >
        <!-- Imagen y nombre -->
        <section class="my-profile-image">
            <div class="avatar-wrapper" id="btn-avatar">
                <img id="profile-avatar" src="/user.png" alt="user" />
                <div class="avatar-overlay">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"
                        ></path>
                    </svg>
                </div>
            </div>
            <p id="profile-saludo">Cargando...</p>
            <span id="profile-rol" class="rol-badge" style="margin-top: 8px;"
                >—</span
            >
        </section>

        <!-- Información personal -->
        <section class="my-profile-info">
            <div class="my-profile-title">
                <h2>Mi información personal</h2>
                <hr />
            </div>

            <!-- Modo ver -->
            <div id="view-mode">
                <div class="my-profile-grid">
                    <div class="my-profile-item">
                        <label>Nombre completo</label>
                        <input type="text" id="view-nombre" disabled />
                    </div>
                    <div class="my-profile-item">
                        <label>Nombre de Usuario</label>
                        <input type="text" id="view-username" disabled />
                    </div>
                    <div class="my-profile-item">
                        <label>Correo Electrónico</label>
                        <input type="email" id="view-email" disabled />
                    </div>
                    <div class="my-profile-item">
                        <label
                            >Número de teléfono <span
                                style="opacity:0.4; font-size:11px;"
                                >(opcional)</span
                            ></label
                        >
                        <input type="tel" id="view-telefono" disabled />
                    </div>
                    <div class="my-profile-item">
                        <label>Miembro desde</label>
                        <input type="text" id="view-fecha" disabled />
                    </div>
                </div>
                <div class="my-profile-buttons">
                    <button class="acpbutton" id="btn-change-password"
                        >Cambiar contraseña</button
                    >
                    <button class="acbtmodify" id="btn-edit"
                        >Editar información</button
                    >
                </div>
            </div>

            <!-- Modo editar -->
            <div id="edit-mode" style="display:none">
                <div class="my-profile-grid">
                    <div class="my-profile-item">
                        <label>Nombre</label>
                        <input type="text" id="edit-nombre" />
                    </div>
                    <div class="my-profile-item">
                        <label>Apellidos</label>
                        <input type="text" id="edit-apellidos" />
                    </div>
                    <div class="my-profile-item">
                        <label>Nombre de Usuario</label>
                        <input type="text" id="edit-username" />
                    </div>
                    <div class="my-profile-item">
                        <label>Correo Electrónico</label>
                        <input type="email" id="edit-email" />
                    </div>
                    <div class="my-profile-item">
                        <label
                            >Teléfono <span style="opacity:0.4; font-size:11px;"
                                >(opcional)</span
                            ></label
                        >
                        <input
                            type="tel"
                            id="edit-telefono"
                            placeholder="+34 600 000 000"
                        />
                    </div>
                </div>
                <p
                    id="edit-msg"
                    style="font-size:13px; margin: 8px 0; display:none"
                >
                </p>
                <div class="my-profile-buttons">
                    <button class="acsbutton" id="btn-cancel-edit"
                        >Cancelar</button
                    >
                    <button class="acpbutton" id="btn-save-edit"
                        >Guardar cambios</button
                    >
                </div>
            </div>

            <!-- Modo cambiar contraseña -->
            <div id="password-mode" style="display:none">
                <div class="my-profile-grid">
                    <div class="my-profile-item">
                        <label>Contraseña actual</label>
                        <input
                            type="password"
                            id="current-password"
                            placeholder="••••••••"
                        />
                    </div>
                    <div class="my-profile-item">
                        <label>Nueva contraseña</label>
                        <input
                            type="password"
                            id="new-password"
                            placeholder="••••••••"
                        />
                    </div>
                    <div class="my-profile-item">
                        <label>Confirmar contraseña</label>
                        <input
                            type="password"
                            id="confirm-password"
                            placeholder="••••••••"
                        />
                    </div>
                </div>
                <p
                    id="password-msg"
                    style="font-size:13px; margin: 8px 0; display:none"
                >
                </p>
                <div class="my-profile-buttons">
                    <button class="acsbutton" id="btn-cancel-password"
                        >Cancelar</button
                    >
                    <button class="acpbutton" id="btn-save-password"
                        >Cambiar contraseña</button
                    >
                </div>
            </div>
        </section>

        <!-- Citas -->
        <section class="my-profile-nextdates">
            <nav>
                <button id="btn-proximas" class="active-tab"
                    >Próximas Citas</button
                >
                <button id="btn-historial">Historial</button>
            </nav>
            <div id="tab-proximas" class="my-profile-dates">
                <p class="my-profile-not">No tienes citas próximas</p>
            </div>
            <div
                id="tab-historial"
                class="my-profile-dates"
                style="display:none"
            >
                <p class="my-profile-not">No tienes citas en el historial</p>
            </div>
        </section>
    </main>
</Layout>

<script>
    import { navigate } from "astro:transitions/client";

    document.addEventListener("astro:page-load", async () => {
        // — Cargar sesión —
        const res = await fetch("/api/auth/session");
        const { session } = await res.json();
        if (!session) {
            navigate("/login");
            return;
        }

        const rolLabels: Record<string, string> = {
            cliente: "Cliente",
            empleado: "Empleado",
            admin: "Administrador",
            dueno: "Dueño",
        };
        const rolColors: Record<string, string> = {
            cliente: "#3498db",
            empleado: "#2ecc71",
            admin: "#e67e22",
            dueno: "#f0ce08",
        };

        // — Rellenar datos —
        const avatar = document.getElementById(
            "profile-avatar",
        ) as HTMLImageElement;
        avatar.src = `/api/auth/avatar/${session.id}?t=${Date.now()}`;
        avatar.onerror = () => {
            avatar.src = "/user.png";
        };

        document.getElementById("profile-saludo")!.textContent =
            `Hola, ${session.nombre} ${session.apellidos}`;

        const rolBadge = document.getElementById("profile-rol") as HTMLElement;
        rolBadge.textContent = rolLabels[session.rol] || session.rol;
        rolBadge.style.backgroundColor =
            (rolColors[session.rol] || "#888") + "22";
        rolBadge.style.color = rolColors[session.rol] || "#888";
        rolBadge.style.borderColor = (rolColors[session.rol] || "#888") + "55";

        const fechaFormateada = new Date(session.created_at).toLocaleDateString(
            "es-ES",
            {
                day: "numeric",
                month: "long",
                year: "numeric",
            },
        );

        (document.getElementById("view-nombre") as HTMLInputElement).value =
            `${session.nombre} ${session.apellidos}`;
        (document.getElementById("view-username") as HTMLInputElement).value =
            session.username || "";
        (document.getElementById("view-email") as HTMLInputElement).value =
            session.email || "";
        (document.getElementById("view-telefono") as HTMLInputElement).value =
            session.telefono || "No añadido";
        (document.getElementById("view-fecha") as HTMLInputElement).value =
            fechaFormateada;
        (document.getElementById("edit-nombre") as HTMLInputElement).value =
            session.nombre || "";
        (document.getElementById("edit-apellidos") as HTMLInputElement).value =
            session.apellidos || "";
        (document.getElementById("edit-username") as HTMLInputElement).value =
            session.username || "";
        (document.getElementById("edit-email") as HTMLInputElement).value =
            session.email || "";
        (document.getElementById("edit-telefono") as HTMLInputElement).value =
            session.telefono || "";

        // — Avatar upload —
        document.getElementById("btn-avatar")?.addEventListener("click", () => {
            const input = document.createElement("input");
            input.type = "file";
            input.accept = "image/*";
            input.click();
            input.addEventListener("change", async () => {
                const file = input.files?.[0];
                if (!file) return;
                const formData = new FormData();
                formData.append("avatar", file);
                const res = await fetch("/api/auth/avatar", {
                    method: "POST",
                    body: formData,
                });
                if (res.ok)
                    avatar.src = `/api/auth/avatar/${session.id}?t=${Date.now()}`;
                else alert("Error al subir la imagen.");
            });
        });

        // — Editar información —
        const viewMode = document.getElementById("view-mode")!;
        const editMode = document.getElementById("edit-mode")!;
        const passwordMode = document.getElementById("password-mode")!;
        const editMsg = document.getElementById("edit-msg") as HTMLElement;

        document.getElementById("btn-edit")?.addEventListener("click", () => {
            viewMode.style.display = "none";
            editMode.style.display = "block";
            passwordMode.style.display = "none";
        });

        document
            .getElementById("btn-cancel-edit")
            ?.addEventListener("click", () => {
                viewMode.style.display = "block";
                editMode.style.display = "none";
                editMsg.style.display = "none";
            });

        document
            .getElementById("btn-save-edit")
            ?.addEventListener("click", async () => {
                const nombre = (
                    document.getElementById("edit-nombre") as HTMLInputElement
                ).value.trim();
                const apellidos = (
                    document.getElementById(
                        "edit-apellidos",
                    ) as HTMLInputElement
                ).value.trim();
                const username = (
                    document.getElementById("edit-username") as HTMLInputElement
                ).value.trim();
                const email = (
                    document.getElementById("edit-email") as HTMLInputElement
                ).value.trim();
                const telefono = (
                    document.getElementById("edit-telefono") as HTMLInputElement
                ).value.trim();

                const res = await fetch("/api/auth/update", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        nombre,
                        apellidos,
                        username,
                        email,
                        telefono,
                    }),
                });
                const data = await res.json();

                if (res.ok) {
                    (
                        document.getElementById(
                            "view-nombre",
                        ) as HTMLInputElement
                    ).value = `${nombre} ${apellidos}`;
                    (
                        document.getElementById(
                            "view-username",
                        ) as HTMLInputElement
                    ).value = username;
                    (
                        document.getElementById(
                            "view-email",
                        ) as HTMLInputElement
                    ).value = email;
                    (
                        document.getElementById(
                            "view-telefono",
                        ) as HTMLInputElement
                    ).value = telefono || "No añadido";
                    document.getElementById("profile-saludo")!.textContent =
                        `Hola, ${nombre} ${apellidos}`;
                    viewMode.style.display = "block";
                    editMode.style.display = "none";
                } else {
                    editMsg.textContent = data.message || "Error al guardar.";
                    editMsg.style.display = "block";
                    editMsg.style.color = "#e74c3c";
                }
            });

        // — Cambiar contraseña —
        document
            .getElementById("btn-change-password")
            ?.addEventListener("click", () => {
                viewMode.style.display = "none";
                passwordMode.style.display = "block";
                editMode.style.display = "none";
            });

        document
            .getElementById("btn-cancel-password")
            ?.addEventListener("click", () => {
                viewMode.style.display = "block";
                passwordMode.style.display = "none";
            });

        document
            .getElementById("btn-save-password")
            ?.addEventListener("click", async () => {
                const currentPassword = (
                    document.getElementById(
                        "current-password",
                    ) as HTMLInputElement
                ).value;
                const newPassword = (
                    document.getElementById("new-password") as HTMLInputElement
                ).value;
                const confirmPassword = (
                    document.getElementById(
                        "confirm-password",
                    ) as HTMLInputElement
                ).value;
                const passwordMsg = document.getElementById(
                    "password-msg",
                ) as HTMLElement;

                if (newPassword !== confirmPassword) {
                    passwordMsg.textContent = "Las contraseñas no coinciden.";
                    passwordMsg.style.color = "#e74c3c";
                    passwordMsg.style.display = "block";
                    return;
                }
                if (newPassword.length < 6) {
                    passwordMsg.textContent =
                        "La contraseña debe tener al menos 6 caracteres.";
                    passwordMsg.style.color = "#e74c3c";
                    passwordMsg.style.display = "block";
                    return;
                }

                const res = await fetch("/api/auth/change-password", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ currentPassword, newPassword }),
                });

                if (res.ok) {
                    passwordMsg.textContent =
                        "✓ Contraseña cambiada correctamente.";
                    passwordMsg.style.color = "#2ecc71";
                    passwordMsg.style.display = "block";
                    (
                        document.getElementById(
                            "current-password",
                        ) as HTMLInputElement
                    ).value = "";
                    (
                        document.getElementById(
                            "new-password",
                        ) as HTMLInputElement
                    ).value = "";
                    (
                        document.getElementById(
                            "confirm-password",
                        ) as HTMLInputElement
                    ).value = "";
                    setTimeout(() => {
                        viewMode.style.display = "block";
                        passwordMode.style.display = "none";
                        passwordMsg.style.display = "none";
                    }, 2000);
                } else {
                    const data = await res.json();
                    passwordMsg.textContent =
                        data.message || "Error al cambiar la contraseña.";
                    passwordMsg.style.color = "#e74c3c";
                    passwordMsg.style.display = "block";
                }
            });

        // — Tabs citas —
        const btnProximas = document.getElementById("btn-proximas")!;
        const btnHistorial = document.getElementById("btn-historial")!;
        const tabProximas = document.getElementById("tab-proximas")!;
        const tabHistorial = document.getElementById("tab-historial")!;

        btnProximas.addEventListener("click", () => {
            tabProximas.style.display = "flex";
            tabHistorial.style.display = "none";
            btnProximas.classList.add("active-tab");
            btnHistorial.classList.remove("active-tab");
        });

        btnHistorial.addEventListener("click", () => {
            tabProximas.style.display = "none";
            tabHistorial.style.display = "flex";
            btnHistorial.classList.add("active-tab");
            btnProximas.classList.remove("active-tab");
        });

        // — Cargar citas —
        const citasRes = await fetch("/api/citas/miscitas");
        const { proximas, historial } = await citasRes.json();

        const statusConfig: Record<string, { label: string; color: string }> = {
            pending: { label: "Pendiente", color: "#f39c12" },
            confirmed: { label: "Confirmada", color: "#2ecc71" },
            completed: { label: "Completada", color: "#3498db" },
            cancelled: { label: "Cancelada", color: "#e74c3c" },
        };

        const renderCita = (cita: any) => {
            const fecha = new Date(cita.start).toLocaleDateString("es-ES", {
                weekday: "long",
                day: "numeric",
                month: "long",
            });
            const hora = new Date(cita.start).toLocaleTimeString("es-ES", {
                hour: "2-digit",
                minute: "2-digit",
            });
            const { label, color } =
                statusConfig[cita.status] || statusConfig.pending;

            return `
                <div class="cita-card">
                    <div class="cita-card-left">
                        <div class="cita-fecha">
                            <span class="cita-dia">${new Date(cita.start).getDate()}</span>
                            <span class="cita-mes">${new Date(cita.start).toLocaleDateString("es-ES", { month: "short" })}</span>
                        </div>
                    </div>
                    <div class="cita-card-body">
                        <div class="cita-card-top">
                            <p class="cita-service">${cita.service}</p>
                            <span class="cita-status" style="background:${color}22; color:${color}; border-color:${color}55">${label}</span>
                        </div>
                        <p class="cita-hora">${fecha} a las ${hora}</p>
                    </div>
                    ${
                        cita.status === "pending" || cita.status === "confirmed"
                            ? `<button class="cita-cancel-btn acbtdeny" data-id="${cita.id}">Cancelar</button>`
                            : ""
                    }
                </div>
            `;
        };

        if (proximas.length > 0) {
            tabProximas.innerHTML = proximas.map(renderCita).join("");
        }
        if (historial.length > 0) {
            tabHistorial.innerHTML = historial.map(renderCita).join("");
        }

        // — Cancelar cita —
        document.querySelectorAll(".cita-cancel-btn").forEach((btn) => {
            btn.addEventListener("click", async () => {
                if (!confirm("¿Seguro que quieres cancelar esta cita?")) return;
                const id = (btn as HTMLElement).dataset.id;
                const res = await fetch("/api/citas/cancel", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id }),
                });
                if (res.ok) {
                    const card = btn.closest(".cita-card") as HTMLElement;
                    const statusEl = card.querySelector(
                        ".cita-status",
                    ) as HTMLElement;
                    statusEl.textContent = "Cancelada";
                    statusEl.style.cssText =
                        "background:#e74c3c22; color:#e74c3c; border-color:#e74c3c55";
                    btn.remove();
                }
            });
        });
    });
</script>
