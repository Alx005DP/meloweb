	<div class="form-modal" id="home-force-password-modal">
		<div class="form-modal-box success" style="width:min(92vw, 560px); align-items:stretch;">
			<h2 style="margin:0;">Cambia tu contraseña</h2>
			<p style="margin-top:-8px;">
				Has iniciado sesión con una contraseña temporal. Debes cambiarla antes de continuar.
			</p>

			<form id="home-force-password-form" style="display:flex; flex-direction:column; gap:12px; width:100%;">
				<label for="home-force-new-password">Nueva contraseña</label>
				<input type="password" id="home-force-new-password" placeholder="Introduce tu nueva contraseña" />

				<div
					class="info-contain-error password-presets"
					id="home-force-password-rules"
					style="display:block !important;"
				>
					<p id="home-force-password-mayus">Debe de contener alguna mayúscula</p>
					<p id="home-force-password-number">Debe de contener algún numero</p>
					<p id="home-force-password-sign">Debe de contener algún signo -+*Â¿?!</p>
					<p id="home-force-password-max6">Debe de contener mínimo 6 caracteres</p>
				</div>

				<label for="home-force-confirm-password">Confirmar contraseña</label>
				<input type="password" id="home-force-confirm-password" placeholder="Repite tu nueva contraseña" />

				<p id="home-force-password-msg" style="margin:0; display:none; text-align:left;"></p>

				<div style="display:flex; justify-content:flex-end;">
					<button type="submit" class="acpbutton" id="home-force-password-submit">
						Guardar nueva contraseña
					</button>
				</div>
			</form>
		</div>
	</div>
</Layout>

<script>
	const PASSWORD_SIGN_REGEX = /[-+*Â¿?!]/

	const setupForcePasswordOnHome = () => {
		const modal = document.getElementById("home-force-password-modal") as HTMLDivElement | null
		const form = document.getElementById("home-force-password-form") as HTMLFormElement | null
		const passwordInput = document.getElementById("home-force-new-password") as HTMLInputElement | null
		const confirmInput = document.getElementById("home-force-confirm-password") as HTMLInputElement | null
		const submitButton = document.getElementById("home-force-password-submit") as HTMLButtonElement | null
		const msg = document.getElementById("home-force-password-msg") as HTMLParagraphElement | null
		const reqMayus = document.getElementById("home-force-password-mayus") as HTMLParagraphElement | null
		const reqNumber = document.getElementById("home-force-password-number") as HTMLParagraphElement | null
		const reqSign = document.getElementById("home-force-password-sign") as HTMLParagraphElement | null
		const reqMax6 = document.getElementById("home-force-password-max6") as HTMLParagraphElement | null
		const rules = document.getElementById("home-force-password-rules") as HTMLElement | null

		if (!modal || !form || !passwordInput || !confirmInput || !submitButton || !msg || !reqMayus || !reqNumber || !reqSign || !reqMax6 || !rules || modal.dataset.initialized === "true") return
		modal.dataset.initialized = "true"

		const setMessage = (text = "", color = "#e74c3c") => {
			msg.textContent = text
			msg.style.display = text ? "block" : "none"
			msg.style.color = color
		}

		const updateRules = () => {
			const val = passwordInput.value
			const checks = [
				{ el: reqMayus, ok: /[A-Z]/.test(val) },
				{ el: reqNumber, ok: /[0-9]/.test(val) },
				{ el: reqSign, ok: PASSWORD_SIGN_REGEX.test(val) },
				{ el: reqMax6, ok: val.length >= 6 },
			]

			checks.forEach(({ el, ok }) => {
				el.classList.toggle("req-ok", ok)
				el.classList.toggle("req-fail", !ok)
			})

			const allOk = checks.every(({ ok }) => ok)
			rules.style.backgroundColor = allOk ? "#2ecc7117" : "#7f000017"
			rules.style.borderColor = allOk ? "#2ecc7142" : "#b2000042"
			return allOk
		}

		const params = new URLSearchParams(window.location.search)
		if (params.get("force_password_change") === "true") {
			form.reset()
			updateRules()
			setMessage("")
			submitButton.disabled = false
			submitButton.textContent = "Guardar nueva contraseña"
			modal.classList.add("active")
		}

		passwordInput.addEventListener("input", updateRules)

		form.addEventListener("submit", async (event) => {
			event.preventDefault()
			setMessage("")

			const newPassword = passwordInput.value
			const confirmPassword = confirmInput.value

			if (!updateRules()) {
				setMessage("La nueva contraseña no cumple los requisitos.")
				return
			}

			if (newPassword !== confirmPassword) {
				setMessage("Las contraseñas no coinciden.")
				return
			}

			submitButton.disabled = true
			submitButton.textContent = "Guardando..."

			try {
				const res = await fetch("/api/auth/change-password", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ newPassword }),
				})

				const data = await res.json().catch(() => ({}))
				if (!res.ok) {
					setMessage(data.message || "No se pudo cambiar la contraseña.")
					submitButton.disabled = false
					submitButton.textContent = "Guardar nueva contraseña"
					return
				}

				window.location.href = "/"
			} catch {
				setMessage("No se pudo cambiar la contraseña.")
				submitButton.disabled = false
				submitButton.textContent = "Guardar nueva contraseña"
			}
		})
	}

	setupForcePasswordOnHome()
	document.addEventListener("astro:page-load", setupForcePasswordOnHome)
</script>

<script type="module" src="/scripts/animations.js"></script>
