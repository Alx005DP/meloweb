---
import Layout from "../layouts/Layouts.astro"
import AppModal from "../components/AppModal.jsx"
---

<Layout title="Recuperar password">
    <AppModal client:load modalId="forgot-password-feedback" />

    <main style="margin: 15vh 0px; top: 0px; height: 100%; display: flex; justify-content: center;">
        <form id="forgot-password-form" class="form-forgot-pass">
            <div class="contenedor">
                <h1 id="forgot-title">Recupera tu password</h1>
                <p id="forgot-subtitle" style="text-align: center; font-size: 18px; margin-top: 30px;">
                    Escribe tu email y te enviaremos un enlace para cambiar tu password.
                </p>
                <hr />

                <div id="forgot-email-step" class="forgot-item">
                    <label for="email">Correo Electrónico:</label>
                    <input type="email" name="email" id="email" placeholder="example@domain.com" />
                </div>

                <div id="forgot-reset-step" style="display:none;">
                    <div class="forgot-item">
                    <label for="password">Nueva Contraseña</label>
                    <input type="password" name="password" id="password" />
                    </div>
                    <div class="info-contain-error password-presets" style="display:block !important;">
                        <p id="password-mayus">Debe contener alguna mayuscula</p>
                        <p id="password-number">Debe contener algun numero</p>
                        <p id="password-sign">Debe contener algun signo -+*?!</p>
                        <p id="password-max6">Debe contener minimo 6 caracteres</p>
                    </div>

                    <div class="forgot-item">
                    <label for="confirm-password">Confirmar Contraseña</label>
                    <input type="password" name="confirm-password" id="confirm-password" />
                    </div>
                    <div class="info-contain-error" id="forgot-password-error">
                        <p>Las contraseñas no coinciden</p>
                    </div>
                </div>

                <input id="forgot-submit" style="margin: 10px 0px;" class="acpbutton" type="submit" value="Enviar enlace" />
            </div>
        </form>
    </main>
</Layout>

<script>
    import { navigate } from "astro:transitions/client"

    const openModal = (config: Record<string, unknown>) => {
        window.dispatchEvent(new CustomEvent("app-modal:open", {
            detail: {
                id: "forgot-password-feedback",
                config,
            },
        }))
    }

    const showModal = (
        type: "success" | "error",
        title: string,
        text: string,
        closeOnBackdrop = true,
    ) => {
        openModal({
            kind: "message",
            type,
            title,
            text,
            buttonText: "Aceptar",
            showButton: true,
            showProgress: false,
            closeOnBackdrop,
            showCloseButton: false,
        })
    }

    const setupForgotPassword = async () => {
        const form = document.getElementById("forgot-password-form") as HTMLFormElement | null
        if (!form || form.dataset.initialized === "true") return

        form.dataset.initialized = "true"

        const params = new URLSearchParams(window.location.search)
        const token = params.get("token") || ""
        const isResetMode = Boolean(token)

        const title = document.getElementById("forgot-title") as HTMLHeadingElement
        const subtitle = document.getElementById("forgot-subtitle") as HTMLParagraphElement
        const emailStep = document.getElementById("forgot-email-step") as HTMLDivElement
        const resetStep = document.getElementById("forgot-reset-step") as HTMLDivElement
        const submit = document.getElementById("forgot-submit") as HTMLInputElement
        const emailInput = document.getElementById("email") as HTMLInputElement
        const passwordInput = document.getElementById("password") as HTMLInputElement
        const confirmInput = document.getElementById("confirm-password") as HTMLInputElement
        const passwordError = document.getElementById("forgot-password-error") as HTMLElement
        const reqMayus = document.getElementById("password-mayus") as HTMLParagraphElement
        const reqNumber = document.getElementById("password-number") as HTMLParagraphElement
        const reqSign = document.getElementById("password-sign") as HTMLParagraphElement
        const reqMax6 = document.getElementById("password-max6") as HTMLParagraphElement

        const checksPassword = (value: string) => {
            return [
                { el: reqMayus, ok: /[A-Z]/.test(value) },
                { el: reqNumber, ok: /[0-9]/.test(value) },
                { el: reqSign, ok: /[-+*?!]/.test(value) },
                { el: reqMax6, ok: value.length >= 6 },
            ]
        }

        const refreshPasswordHints = () => {
            const checks = checksPassword(passwordInput.value)
            checks.forEach(({ el, ok }) => {
                el.classList.toggle("req-ok", ok)
                el.classList.toggle("req-fail", !ok)
            })

            const allOk = checks.every(({ ok }) => ok)
            const container = document.querySelector(".password-presets") as HTMLElement
            if (container) {
                container.style.backgroundColor = allOk ? "#2ecc7117" : "#7f000017"
                container.style.borderColor = allOk ? "#2ecc7142" : "#b2000042"
            }
        }

        if (isResetMode) {
            submit.disabled = true
            submit.value = "Comprobando..."

            try {
                const validationRes = await fetch(`/api/auth/forgot-password/validate?token=${encodeURIComponent(token)}`)
                const validationData = await validationRes.json()

                if (!validationRes.ok || !validationData.valid) {
                    title.textContent = "Enlace no disponible"
                    subtitle.textContent = validationData.message || "Este enlace ya no se puede usar."
                    emailStep.style.display = "flex"
                    resetStep.style.display = "none"
                    submit.value = "Enviar enlace"
                    submit.disabled = false
                    showModal("error", "Enlace no valido", validationData.message || "Este enlace ya no se puede usar.")
                    if (window.location.search) {
                        window.history.replaceState({}, "", "/forgot-password")
                    }
                    return
                }
            } catch {
                title.textContent = "No se pudo validar el enlace"
                subtitle.textContent = "Vuelve a pedir un nuevo enlace para cambiar tu password."
                emailStep.style.display = "flex"
                resetStep.style.display = "none"
                submit.value = "Enviar enlace"
                submit.disabled = false
                showModal("error", "Error inesperado", "No se pudo validar el enlace.")
                if (window.location.search) {
                    window.history.replaceState({}, "", "/forgot-password")
                }
                return
            }

            title.textContent = "Pon tu nueva password"
            subtitle.textContent = "Introduce tu nueva contraseña."
            emailStep.style.display = "none"
            resetStep.style.display = "block"
            submit.value = "Guardar contraseña"
            submit.disabled = false
            passwordInput.addEventListener("input", refreshPasswordHints)
            refreshPasswordHints()
        } else {
            title.textContent = "Recupera tu password"
            subtitle.textContent = "Escribe tu email y te enviaremos un enlace para cambiar tu password."
            emailStep.style.display = "flex"
            resetStep.style.display = "none"
            submit.value = "Enviar enlace"
        }

        form.addEventListener("submit", async (event) => {
            event.preventDefault()
            passwordError.style.display = "none"
            submit.disabled = true

            try {
                if (!isResetMode) {
                    const email = emailInput.value.trim()
                    if (!email) {
                        showModal("error", "Falta el email", "Introduce tu email para continuar.")
                        submit.disabled = false
                        return
                    }

                    submit.value = "Enviando..."

                    const res = await fetch("/api/auth/forgot-password/request", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ email }),
                    })
                    const data = await res.json()

                    if (!res.ok) {
                        showModal("error", "No se pudo enviar", data.message || "No se pudo procesar la solicitud.")
                        submit.disabled = false
                        submit.value = "Enviar enlace"
                        return
                    }

                    showModal("success", "Revisa tu email", data.message || "Si el email existe, te hemos enviado un enlace.")
                    form.reset()
                    submit.disabled = false
                    submit.value = "Enviar enlace"
                    return
                }

                const password = passwordInput.value
                const confirmPassword = confirmInput.value
                const validChecks = checksPassword(password)
                const passwordOk = validChecks.every(({ ok }) => ok)

                if (!passwordOk) {
                    showModal("error", "Password invalida", "La nueva password no cumple los requisitos.")
                    submit.disabled = false
                    submit.value = "Guardar password"
                    return
                }

                if (password !== confirmPassword) {
                    passwordError.style.display = "block"
                    submit.disabled = false
                    submit.value = "Guardar password"
                    return
                }

                submit.value = "Guardando..."

                const res = await fetch("/api/auth/forgot-password/reset", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        token,
                        password,
                    }),
                })
                const data = await res.json()

                if (!res.ok) {
                    showModal("error", "No se pudo cambiar", data.message || "No se pudo cambiar la password.")
                    submit.disabled = false
                    submit.value = "Guardar password"
                    return
                }

                if (window.location.search) {
                    window.history.replaceState({}, "", "/forgot-password")
                }
                showModal("success", "Password actualizada", data.message || "Ya puedes iniciar sesion con tu nueva password.", false)
                setTimeout(() => navigate("/login"), 2000)
            } catch {
                showModal("error", "Error inesperado", "No se pudo completar la accion.")
                submit.disabled = false
                submit.value = isResetMode ? "Guardar password" : "Enviar enlace"
            }
        })
    }

    setupForgotPassword()
    document.addEventListener("astro:page-load", setupForgotPassword)
</script>
