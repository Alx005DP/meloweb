---
import Layout from "../layouts/Layouts.astro";
import AppModal from "../components/AppModal.jsx";
---

<Layout title="Acceder">
	<main
		style="margin: 15vh 0px; top: 0px; height: 100%; display: flex; justify-content: center;"
	>
		<form id="login">
			<div class="contenedor">
				<h1>Acceder</h1>
				<hr />
				<label for="mail">Correo Electronico:</label>
				<input
					type="email"
					name="mail"
					id="mail"
					placeholder="example@domain.com"
				/>
				<label for="password">Contraseña:</label>
				<input
					type="password"
					name="password"
					id="password"
					placeholder="******"
				/>
				<div class="item">
					<input
						type="checkbox"
						name="keepsesion"
						id="keepsesion"
					/><label for="keepsesion">Mantener inicio de sesion</label>
				</div>

				<input class="acpbutton" type="submit" value="Acceder" />
				<div class="setpswdre">
					<a href="/forgot-password" class="lwsv">He olvidado la contraseña</a>
					<a href="/register" class="lwsv"
						>No tengo cuenta, registrarme</a
					>
				</div>
			</div>
		</form>
	</main>

	<AppModal client:load modalId="login-feedback" />
</Layout>

<script>
import { navigate } from "astro:transitions/client"

const openModal = (config: Record<string, unknown>) => {
	window.dispatchEvent(new CustomEvent("app-modal:open", {
		detail: {
			id: "login-feedback",
			config,
		},
	}))
}

const showModal = (type: "success" | "error", title: string, text: string, redirect?: string) => {
	openModal({
		kind: "message",
		type,
		title,
		text,
		buttonText: type === "success" ? "Aceptar" : "Intentar de nuevo",
		showButton: type !== "success",
		showProgress: type === "success",
		closeOnBackdrop: false,
		showCloseButton: false,
	})

	if (type === "success") {
		setTimeout(() => navigate(redirect || "/"), 2000)
	}
}

const setupLoginPage = () => {
	const form = document.getElementById("login") as HTMLFormElement | null
	if (!form || form.dataset.initialized === "true") return

	form.dataset.initialized = "true"

	const params = new URLSearchParams(window.location.search)
	const redirectParam = params.get("redirect")
	const safeRedirect = redirectParam && redirectParam.startsWith("/") ? redirectParam : null
	const registerLink = document.querySelector('a[href="/register"]') as HTMLAnchorElement | null

	if (registerLink && safeRedirect) {
		registerLink.href = `/register?redirect=${encodeURIComponent(safeRedirect)}`
	}

	if (params.get("verified") === "true") {
		openModal({
			kind: "message",
			type: "success",
			title: "¡Cuenta verificada!",
			text: "Tu cuenta ha sido verificada correctamente. Ya puedes iniciar sesión.",
			buttonText: "Iniciar sesión",
			showButton: true,
			showProgress: false,
			closeOnBackdrop: false,
			showCloseButton: false,
		})
	}

	window.addEventListener("app-modal:closed", ((event: Event) => {
		const detail = (event as CustomEvent).detail
		if (detail?.id !== "login-feedback") return

		const btn = form.querySelector("input[type=submit]") as HTMLInputElement | null
		if (!btn) return

		btn.value = "Acceder"
		btn.disabled = false
	}) as EventListener)

	form.addEventListener("submit", async (e) => {
		e.preventDefault()

		const mail = (document.getElementById("mail") as HTMLInputElement).value.trim()
		const password = (document.getElementById("password") as HTMLInputElement).value
		const keepSession = (document.getElementById("keepsesion") as HTMLInputElement).checked

		if (!mail || !password) {
			showModal("error", "Campos vacíos", "Por favor rellena todos los campos.")
			return
		}

		const btn = form.querySelector("input[type=submit]") as HTMLInputElement
		btn.value = "Accediendo..."
		btn.disabled = true

		const res = await fetch("/api/auth/login", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ email: mail, password, keepSession })
		})

		const data = await res.json()

		if (!res.ok) {
			btn.value = "Acceder"
			btn.disabled = false

			if (data.error === "invalid_credentials") {
				showModal("error", "Credenciales incorrectas", "El email o la contraseña no son correctos.")
				return
			}
			if (data.error === "rate_limit") {
				showModal("error", "Demasiados intentos", "Espera unos minutos e inténtalo de nuevo.")
				return
			}

			showModal("error", "Error al acceder", "Ha ocurrido un error inesperado. Inténtalo más tarde.")
			return
		}

		const redirectMap: Record<string, string> = {
			cliente: "/",
			empleado: "/",
			admin: "/admin",
			dueno: "/"
		}

		const nextUrl = data.mustChangePassword
			? "/?force_password_change=true"
			: safeRedirect || redirectMap[data.usuario.rol] || "/"

		showModal(
			"success",
			"¡Bienvenido de nuevo!",
			data.mustChangePassword
				? "Has iniciado sesión con una contraseña temporal. Debes cambiarla ahora."
				: "Has iniciado sesión correctamente. Redirigiendo...",
			nextUrl
		)
	})
}

setupLoginPage()
document.addEventListener("astro:page-load", setupLoginPage)
</script>
