---
import Layout from "../layouts/Layouts.astro";
---

<Layout title="Acceder">
	<main
		style="margin: 15vh 0px; top: 0px; height: 100%; display: flex; justify-content: center;"
	>
		<form action="" id="login">
			<div class="contenedor">
				<h1>Acceder</h1>
				<hr />
				<label for="mail">Correo Electronico:</label>
				<input
					type="email"
					name="mail"
					id="mail"
					placeholder="example@domain.com"
				/>
				<label for="password">Contraseña:</label>
				<input
					type="password"
					name="password"
					id="password"
					placeholder="******"
				/>
				<div class="item">
					<input
						type="checkbox"
						name="keepsesion"
						id="keepsesion"
					/><label for="keepsesion">Mantener inicio de sesion</label>
				</div>

				<input class="acpbutton" type="submit" value="Acceder" />
				<div class="setpswdre">
					<a href="#" class="lwsv">He olvidado la contraseña</a>
					<a href="../register" class="lwsv"
						>No tengo cuenta, registrarme</a
					>
				</div>
			</div>
		</form>
	</main>

	<div class="form-modal" id="form-modal">
		<div class="form-modal-box">
			<div class="form-row">
				<i
					id="modal-icon"
					class="fa-sharp-duotone fa-solid fa-circle-xmark"></i>
			</div>
			<div class="form-row">
				<h2 id="modal-title"></h2>
			</div>
			<div class="form-row">
				<p id="modal-text"></p>
			</div>
			<div class="form-row" id="modal-progress-row" style="display:none">
				<div class="form-progress">
					<div class="form-progress-bar" id="modal-progress"></div>
				</div>
			</div>
			<div class="form-row" id="modal-btn-row">
				<button class="acpbutton" id="modal-btn"
					>Intentar de nuevo</button
				>
			</div>
		</div>
	</div>
</Layout>

<script>
import { navigate } from "astro:transitions/client"

// — Elementos —
const form             = document.getElementById("login") as HTMLFormElement
const modal            = document.getElementById("form-modal") as HTMLElement
const modalBox         = modal.querySelector(".form-modal-box") as HTMLElement
const modalIcon        = document.getElementById("modal-icon") as HTMLElement
const modalTitle       = document.getElementById("modal-title") as HTMLElement
const modalText        = document.getElementById("modal-text") as HTMLElement
const modalProgress    = document.getElementById("modal-progress") as HTMLElement
const modalProgressRow = document.getElementById("modal-progress-row") as HTMLElement
const modalBtnRow      = document.getElementById("modal-btn-row") as HTMLElement
const modalBtn         = document.getElementById("modal-btn") as HTMLButtonElement

// — Modal —
const showModal = (type: "success" | "error", title: string, text: string, redirect?: string) => {
    modalBox.className = `form-modal-box ${type}`
    modalIcon.className = type === "success"
        ? "fa-sharp-duotone fa-solid fa-badge-check"
        : "fa-sharp-duotone fa-solid fa-circle-xmark"
    modalTitle.textContent = title
    modalText.textContent  = text
    modal.classList.add("active")

    if (type === "success") {
        modalProgressRow.style.display = "flex"
        modalBtnRow.style.display = "none"
        modalProgress.className = "form-progress-bar animating"
        setTimeout(() => navigate(redirect || "/"), 2000)
    } else {
        modalProgressRow.style.display = "none"
        modalBtnRow.style.display = "flex"
    }
}

modalBtn.addEventListener("click", () => {
    modal.classList.remove("active")
    const btn = form.querySelector("input[type=submit]") as HTMLInputElement
    btn.value = "Acceder"
    btn.disabled = false
})

// — Submit —
form.addEventListener("submit", async (e) => {
    e.preventDefault()

    const mail      = (document.getElementById("mail") as HTMLInputElement).value.trim()
    const password  = (document.getElementById("password") as HTMLInputElement).value
    const keepSession = (document.getElementById("keepsesion") as HTMLInputElement).checked

    if (!mail || !password) {
        showModal("error", "Campos vacíos", "Por favor rellena todos los campos.")
        return
    }

    const btn = form.querySelector("input[type=submit]") as HTMLInputElement
    btn.value = "Accediendo..."
    btn.disabled = true

    // — Llamada a la API —
    const res = await fetch("/api/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: mail, password, keepSession })
    })

    const data = await res.json()

    if (!res.ok) {
        btn.value = "Acceder"
        btn.disabled = false

        if (data.error === "invalid_credentials") {
            showModal("error", "Credenciales incorrectas", "El email o la contraseña no son correctos.")
            return
        }
        if (data.error === "rate_limit") {
            showModal("error", "Demasiados intentos", "Espera unos minutos e inténtalo de nuevo.")
            return
        }

        showModal("error", "Error al acceder", "Ha ocurrido un error inesperado. Inténtalo más tarde.")
        return
    }

    // Redirigir según rol
    const redirectMap: Record<string, string> = {
        cliente:  "/",
        empleado: "/calendar",
        admin:    "/admin",
        dueno:    "/admin"
    }

    showModal("success",
        "¡Bienvenido de nuevo!",
        "Has iniciado sesión correctamente. Redirigiendo...",
        redirectMap[data.usuario.rol] || "/"
    )
})
</script>
