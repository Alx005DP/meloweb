---
import Layout from "../layouts/Layouts.astro";
---

<Layout title="Creador de QR">
    <main
        class="qr-page-main"
        style="margin: 15vh 0px; top: 0px; height: 100%; display: flex; justify-content: center;"
    >
        <div class="qr-creator">
            <!-- Config -->
            <div class="qr-config">
                <h2>Crear QR</h2>
                <hr />

                <!-- Tipo -->
                <div class="qr-type-tabs">
                    <button class="qr-tab active" data-type="url">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                            ></path><path
                                d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                            ></path></svg
                        >
                        URL
                    </button>
                    <button class="qr-tab" data-type="descuento">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                            ></path></svg
                        >
                        Descuento
                    </button>
                    <button class="qr-tab" data-type="mensaje">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                            ></path></svg
                        >
                        Mensaje
                    </button>
                </div>

                <!-- Campos por tipo -->
                <div class="qr-settings">
                    <!-- URL -->
                    <div id="fields-url" class="qr-fields">
                        <div class="qr-row">
                            <label>Título del QR</label>
                            <input
                                type="text"
                                id="url-titulo"
                                placeholder="Ej: Web principal"
                            />
                        </div>
                        <div class="qr-row">
                            <label>URL de destino</label>
                            <input
                                type="url"
                                id="url-valor"
                                placeholder="https://marcoaldany.com"
                            />
                        </div>
                        <div class="qr-row">
                            <label
                                >Máximo de usos <span
                                    style="opacity:0.4; font-size:11px;"
                                    >(vacío = ilimitado)</span
                                ></label
                            >
                            <input
                                type="number"
                                id="url-maxusos"
                                placeholder="100"
                                min="1"
                            />
                        </div>
                    </div>

                    <!-- Descuento -->
                    <div
                        id="fields-descuento"
                        class="qr-fields"
                        style="display:none"
                    >
                        <div class="qr-row">
                            <label>Título del QR</label>
                            <input
                                type="text"
                                id="desc-titulo"
                                placeholder="Ej: Promocion de verano"
                            />
                        </div>
                        <div class="qr-row">
                            <label>Titulo visible del descuento</label>
                            <input
                                type="text"
                                id="desc-visible-title"
                                placeholder="Ej: 10% de descuento"
                            />
                        </div>
                        <div class="qr-row">
                            <label>Tipo de descuento</label>
                            <select id="desc-tipo">
                                <option value="porcentaje"
                                    >Porcentaje (%)</option
                                >
                                <option value="importe">Importe fijo (€)</option
                                >
                            </select>
                        </div>
                        <div class="qr-row">
                            <label>Valor del descuento</label>
                            <input
                                type="number"
                                id="desc-valor"
                                placeholder="10"
                                min="0"
                                step="0.01"
                            />
                        </div>
                        <div class="qr-row">
                            <label
                                >Máximo de usos <span
                                    style="opacity:0.4; font-size:11px;"
                                    >(vacío = ilimitado)</span
                                ></label
                            >
                            <input
                                type="number"
                                id="desc-maxusos"
                                placeholder="50"
                                min="1"
                            />
                        </div>
                        <div class="qr-row">
                            <label>Fecha de caducidad</label>
                            <input type="datetime-local" id="desc-expire" />
                        </div>
                    </div>

                    <!-- Mensaje -->
                    <div
                        id="fields-mensaje"
                        class="qr-fields"
                        style="display:none"
                    >
                        <div class="qr-row">
                            <label>Título del QR</label>
                            <input
                                type="text"
                                id="msg-titulo"
                                placeholder="Ej: Promoción verano"
                            />
                        </div>
                        <div class="qr-row" style="grid-column: 1 / -1">
                            <label>Mensaje</label>
                            <textarea
                                id="msg-valor"
                                placeholder="Escribe tu mensaje aquí..."
                                rows="3"></textarea>
                        </div>
                        <div class="qr-row">
                            <label
                                >Máximo de usos <span
                                    style="opacity:0.4; font-size:11px;"
                                    >(vacío = ilimitado)</span
                                ></label
                            >
                            <input
                                type="number"
                                id="msg-maxusos"
                                placeholder="100"
                                min="1"
                            />
                        </div>
                    </div>
                </div>

                <hr />
                <h3>Personalización</h3>

                <div class="qr-settings">
                    <div class="qr-row">
                        <label>Color del QR</label>
                        <input type="color" id="qr-color" value="#b89e0c" />
                    </div>
                    <div class="qr-row">
                        <label>Color de fondo</label>
                        <input type="color" id="qr-bg" value="#202020" />
                    </div>
                    <div class="qr-row">
                        <label>Forma de los puntos</label>
                        <select id="qr-dots-type">
                            <option value="square">Cuadrado</option>
                            <option value="rounded">Redondeado</option>
                            <option value="dots">Puntos</option>
                            <option value="classy">Classy</option>
                            <option value="classy-rounded"
                                >Classy Rounded</option
                            >
                            <option value="extra-rounded"
                                >Extra Redondeado</option
                            >
                        </select>
                    </div>
                    <div class="qr-row">
                        <label>Forma de las esquinas</label>
                        <select id="qr-corners-type">
                            <option value="square">Cuadrado</option>
                            <option value="dot">Punto</option>
                            <option value="extra-rounded">Redondeado</option>
                        </select>
                    </div>
                    <div class="qr-row">
                        <label>Logo (opcional)</label>
                        <input
                            type="file"
                            id="qr-logo"
                            accept="image/*"
                            value="/marcoaldany.ico"
                        />
                    </div>
                </div>

                <div class="qr-actions">
                    <button class="acsbutton" id="btn-generate">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M3 7V5a2 2 0 0 1 2-2h2"></path><path
                                d="M17 3h2a2 2 0 0 1 2 2v2"></path><path
                                d="M21 17v2a2 2 0 0 1-2 2h-2"></path><path
                                d="M7 21H5a2 2 0 0 1-2-2v-2"></path><rect
                                width="7"
                                height="7"
                                x="7"
                                y="7"
                                rx="1"></rect></svg
                        >
                        Generar QR
                    </button>
                    <button
                        class="acpbutton"
                        id="btn-save"
                        style="display:none"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"
                            ></path><polyline points="17 21 17 13 7 13 7 21"
                            ></polyline><polyline points="7 3 7 8 15 8"
                            ></polyline></svg
                        >
                        Guardar y publicar
                    </button>
                </div>

                <p
                    id="qr-msg"
                    style="font-size:13px; margin-top:8px; display:none"
                >
                </p>
            </div>

            <!-- Preview -->
            <div class="qr-preview">
                <div class="qr-preview-header">
                    <h3>Vista previa</h3>
                    <div
                        class="qr-preview-actions"
                        id="preview-actions"
                        style="display:none"
                    >
                        <button class="acsbutton" id="btn-download-png">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                                ></path><polyline points="7 10 12 15 17 10"
                                ></polyline><line x1="12" x2="12" y1="15" y2="3"
                                ></line></svg
                            >
                            PNG
                        </button>
                        <button class="acsbutton" id="btn-download-svg">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                                ></path><polyline points="7 10 12 15 17 10"
                                ></polyline><line x1="12" x2="12" y1="15" y2="3"
                                ></line></svg
                            >
                            SVG
                        </button>
                        <button class="acsbutton" id="btn-print">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><polyline points="6 9 6 2 18 2 18 9"
                                ></polyline><path
                                    d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"
                                ></path><rect width="12" height="8" x="6" y="14"
                                ></rect></svg
                            >
                            Imprimir
                        </button>
                    </div>
                </div>

                <div class="qr-canvas-wrapper">
                    <div id="qr-card" class="qr-card" style="display:none">
                        <div class="qr-card-header">
                            <img src="/image.png" alt="logo" />
                        </div>

                        <h2 id="qr-card-title"></h2>

                        <div class="qr-card-body">
                            <div id="qr-canvas"></div>
                        </div>

                        <p id="qr-card-text"></p>
                    </div>
                    <p id="qr-placeholder" class="qr-placeholder">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="48"
                            height="48"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="opacity:0.2"
                            ><path d="M3 7V5a2 2 0 0 1 2-2h2"></path><path
                                d="M17 3h2a2 2 0 0 1 2 2v2"></path><path
                                d="M21 17v2a2 2 0 0 1-2 2h-2"></path><path
                                d="M7 21H5a2 2 0 0 1-2-2v-2"></path><rect
                                width="7"
                                height="7"
                                x="7"
                                y="7"
                                rx="1"></rect></svg
                        >
                        Configura tu QR y dale a Generar
                    </p>
                </div>

                <!-- Info del QR generado -->
                <div id="qr-info" class="qr-info-card" style="display:none">
                    <p id="qr-info-tipo"></p>
                    <p id="qr-info-valor"></p>
                </div>
            </div>
        </div>
    </main>
</Layout>



<script>
import QRCodeStyling from "qr-code-styling"
import * as htmlToImage from "html-to-image"

document.addEventListener("astro:page-load", () => {

    let currentType = "url"
    let qrInstance: any = null
    let logoDataUrl = "/marcoaldany.ico" // ✅ logo por defecto
    let currentQRId: string | null = null
    const qrHost = "192.168.0.32"

    // -------------------------
    // TABS
    // -------------------------
    const tabs = document.querySelectorAll(".qr-tab")

    tabs.forEach(tab => {
        tab.addEventListener("click", () => {
            tabs.forEach(t => t.classList.remove("active"))
            tab.classList.add("active")

            currentType = (tab as HTMLElement).dataset.type || "url"

            document.querySelectorAll(".qr-fields").forEach(f => {
                (f as HTMLElement).style.display = "none"
            })

            const fields = document.getElementById(`fields-${currentType}`)
            if (fields) fields.style.display = "grid"
        })
    })

    // -------------------------
    // LOGO UPLOAD
    // -------------------------
    const logoInput = document.getElementById("qr-logo") as HTMLInputElement

    logoInput?.addEventListener("change", () => {
        const file = logoInput.files?.[0]
        if (!file) return

        const reader = new FileReader()
        reader.onload = (e) => {
            logoDataUrl = e.target?.result as string
        }
        reader.readAsDataURL(file)
    })

    // -------------------------
    // ELEMENTOS
    // -------------------------
    const btnGenerate = document.getElementById("btn-generate")
    const qrCanvas = document.getElementById("qr-canvas")!
    const qrPlaceholder = document.getElementById("qr-placeholder") as HTMLElement
    const previewActions = document.getElementById("preview-actions") as HTMLElement

    const qrCard = document.getElementById("qr-card") as HTMLElement
    const qrCardTitle = document.getElementById("qr-card-title") as HTMLElement
    const qrCardText = document.getElementById("qr-card-text") as HTMLElement

    // -------------------------
    // OBTENER DATOS
    // -------------------------
    const getQRData = () => {

        if (currentType === "url") {
            const valor = (document.getElementById("url-valor") as HTMLInputElement).value.trim()
            return { valor, display: valor, visibleTitle: valor }
        }

        if (currentType === "descuento") {
            const tipo = (document.getElementById("desc-tipo") as HTMLSelectElement).value
            const valor = (document.getElementById("desc-valor") as HTMLInputElement).value
            const visibleTitleInput = (document.getElementById("desc-visible-title") as HTMLInputElement).value.trim()
            const defaultVisibleTitle = tipo === "porcentaje"
                ? `${valor}% de descuento`
                : `${valor}€ de descuento`

            return {
                valor: JSON.stringify({
                    tipo,
                    valor,
                    titulo_visible: visibleTitleInput || defaultVisibleTitle
                }),
                display: tipo === "porcentaje"
                    ? `${valor}% de descuento`
                    : `${valor}€ de descuento`
                ,visibleTitle: visibleTitleInput || defaultVisibleTitle
            }
        }

        if (currentType === "mensaje") {
            const valor = (document.getElementById("msg-valor") as HTMLTextAreaElement).value.trim()
            return { valor, display: valor, visibleTitle: valor }
        }

        return { valor: "", display: "", visibleTitle: "" }
    }

    // -------------------------
    // GENERAR QR
    // -------------------------
    btnGenerate?.addEventListener("click", async () => {

        const { valor, display, visibleTitle } = getQRData()

        if (!valor) {
            alert("Rellena los campos")
            return
        }

        const tituloInput = document.getElementById(
            currentType === "url" ? "url-titulo" :
            currentType === "descuento" ? "desc-visible-title" :
            "msg-titulo"
        ) as HTMLInputElement

        const tituloInternoInput = currentType === "descuento"
            ? (document.getElementById("desc-titulo") as HTMLInputElement)
            : null

        const titulo = tituloInput?.value || "Sin título"

        const maxusos = (
            document.getElementById(
                currentType === "url" ? "url-maxusos" :
                currentType === "descuento" ? "desc-maxusos" :
                "msg-maxusos"
            ) as HTMLInputElement
        )?.value

        const expires_at = currentType === "descuento"
            ? (document.getElementById("desc-expire") as HTMLInputElement)?.value
            : null

        // -------------------------
        // CREAR EN BACKEND
        // -------------------------
        const res = await fetch("/api/qr/create", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                tipo: currentType,
                titulo,
                titulo_interno: tituloInternoInput?.value.trim() || titulo,
                valor,
                descuento: currentType === "descuento" ? JSON.parse(valor).valor : null,
                tipo_descuento: currentType === "descuento" ? JSON.parse(valor).tipo : null,
                max_usos: maxusos ? parseInt(maxusos) : null,
                expires_at
            })
        })

        const data = await res.json()

        if (!res.ok) {
            alert("Error al crear QR")
            return
        }

        currentQRId = data.id

        const qrBaseUrl = `${window.location.protocol}//${qrHost}${window.location.port ? `:${window.location.port}` : ""}`
        const qrUrl = `${qrBaseUrl}/api/qr/scan?id=${currentQRId}`

        // -------------------------
        // GENERAR QR VISUAL
        // -------------------------
        const color = (document.getElementById("qr-color") as HTMLInputElement).value
        const bg = (document.getElementById("qr-bg") as HTMLInputElement).value
        const dotsType = (document.getElementById("qr-dots-type") as HTMLSelectElement).value
        const cornType = (document.getElementById("qr-corners-type") as HTMLSelectElement).value

        qrCanvas.innerHTML = ""

        qrInstance = new QRCodeStyling({
            width: 400,
            height: 400,
            type: "svg",
            data: qrUrl,
            dotsOptions: { color, type: dotsType as any },
            cornersSquareOptions: { type: cornType as any },
            backgroundOptions: { color: bg },
            image: logoDataUrl || undefined,
            imageOptions: {
                crossOrigin: "anonymous",
                margin: 8,
                imageSize: 0.3
            }
        })

        qrInstance.append(qrCanvas)

        // -------------------------
        // CARD PREVIEW
        // -------------------------
        qrCardTitle.textContent = currentType === "descuento" ? visibleTitle : titulo
        qrCardText.textContent = display

        qrCard.style.display = "flex"
        qrPlaceholder.style.display = "none"
        previewActions.style.display = "flex"
    })

    // -------------------------
    // DESCARGAR PNG
    // -------------------------
    document.getElementById("btn-download-png")?.addEventListener("click", async () => {
        if (!qrCard) return

        const dataUrl = await htmlToImage.toPng(qrCard, { pixelRatio: 3 })

        const link = document.createElement("a")
        link.download = "qr-card.png"
        link.href = dataUrl
        link.click()
    })

    // -------------------------
    // DESCARGAR SVG
    // -------------------------
    document.getElementById("btn-download-svg")?.addEventListener("click", async () => {
        if (!qrCard) return

        const dataUrl = await htmlToImage.toSvg(qrCard)

        const link = document.createElement("a")
        link.download = "qr-card.svg"
        link.href = dataUrl
        link.click()
    })

    // -------------------------
    // IMPRIMIR
    // -------------------------
    document.getElementById("btn-print")?.addEventListener("click", async () => {
        if (!qrCard) return

        const dataUrl = await htmlToImage.toPng(qrCard, { pixelRatio: 3 })

        const win = window.open("", "_blank")
        if (!win) return

        win.document.write(`
            <html>
            <head>
                <title>Imprimir QR</title>
                <style>
                    body {
                        margin:0;
                        display:flex;
                        justify-content:center;
                        align-items:center;
                        height:100vh;
                    }
                    img {
                        width:400px;
                    }
                </style>
            </head>
            <body>
                <img src="${dataUrl}" />
                <script>
                    window.onload = () => { window.print(); window.close(); }
                <\/script>
            </body>
            </html>
        `)

        win.document.close()
    })

})
</script>
