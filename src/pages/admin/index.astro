                    <div class="admin-card admin-card-10">
                        <h3 class="admin-title-spaced">Ultimos eventos</h3>
                        <div class="admin-grid-10">
                            <div class="admin-surface-row">
                                <strong class="admin-block">03:12 | Backup completado</strong>
                                <span class="admin-muted">Duracion 01:24 | sin incidencias</span>
                            </div>
                            <div class="admin-surface-row">
                                <strong class="admin-block">02:41 | Pico de CPU controlado</strong>
                                <span class="admin-muted">Subida puntual por exportacion de datos</span>
                            </div>
                            <div class="admin-surface-row">
