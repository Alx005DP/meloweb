---
import Layout from "../../layouts/Layouts.astro";
import AppModal from "../../components/AppModal.jsx";
---

<Layout title="Panel de Admin">
    <main
        class="admin-panel-grid"
    >
        <section class="admin-users admin-template">
            <h2>Gestión de Usuarios</h2>
            <nav class="admin-user-settings">
                <input
                    type="text"
                    id="admin-user-search"
                    placeholder="Buscar usuario"
                />
                <button
                    class="acpbutton-small acbtaccept"
                    id="admin-user-create-open"
                    type="button"
                    title="Añadir usuario"
                    aria-label="Añadir usuario"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
                </button>
                <button
                    class="acpbutton-small acbtaccept"
                    id="admin-user-refresh"
                    type="button"
                    title="Recargar usuarios"
                    aria-label="Recargar usuarios"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><polyline points="21 3 21 9 15 9"></polyline></svg>
                </button>
            </nav>
            <div class="admin-search-and-allusers" id="admin-users-list">
                <div class="admin-user">
                    <img src="/user.png" alt="imguser" />
                    <p>Cargando usuarios...</p>
                </div>
            </div>
        </section>
        <section class="admin-db admin-template">
            <h2>Gestión de Base de datos</h2>
        </section>
        </section>
        <section class="admin-server admin-template">
            <h2>Gestión del servidor</h2>
        </section>
    </main>

    <div class="form-modal" id="admin-create-user-modal">
        <div class="form-modal-box success" class="admin-modal-box admin-modal-box-sm">
            <h2 class="admin-no-margin">Añadir usuario</h2>
            <p class="admin-subtitle">
                Se generara una contraseña temporal y se enviara por email. El usuario tendrá que cambiarla al iniciar sesión.
            </p>

            <form id="admin-create-user-form" class="admin-form-grid">
                <input type="email" id="create-email" placeholder="Email" class="admin-col-full" />
                <select id="create-role">
                    <option value="empleado">Empleado</option>
                    <option value="admin">Admin</option>
                    <option value="dueno">Dueño</option>
                </select>
                <input type="text" id="create-username" placeholder="Nombre de usuario" />
                <input type="text" id="create-name" placeholder="Nombre" />
                <input type="text" id="create-lastname" placeholder="Apellidos" />
                <input type="tel" id="create-phone" placeholder="Teléfono" class="admin-col-full" />
                <p id="create-user-msg" class="admin-message admin-col-full"></p>
                <div class="admin-actions-row admin-col-full">
                    <button type="button" class="acsbutton" id="admin-create-user-cancel">Cancelar</button>
                    <button type="submit" class="acpbutton" id="admin-create-user-submit">Crear usuario</button>
                </div>
            </form>
        </div>
    </div>

    <div class="form-modal" id="admin-user-detail-modal">
        <div class="form-modal-box success" class="admin-modal-box admin-modal-box-md">
            <h2 class="admin-no-margin">Información del usuario</h2>
            <p id="admin-user-detail-subtitle" class="admin-subtitle">
                Consulta y edita los datos del usuario.
            </p>

            <form id="admin-user-detail-form" class="admin-form-grid">
                <input type="hidden" id="detail-user-id" />
                <input type="text" id="detail-username" placeholder="Nombre de usuario" disabled />
                <select id="detail-role" disabled>
                    <option value="empleado">Empleado</option>
                    <option value="admin">Admin</option>
                    <option value="dueno">Dueño</option>
                    <option value="cliente">Cliente</option>
                </select>
                <input type="text" id="detail-name" placeholder="Nombre" disabled />
                <input type="text" id="detail-lastname" placeholder="Apellidos" disabled />
                <input type="email" id="detail-email" placeholder="Email" class="admin-col-full" disabled />
                <input type="tel" id="detail-phone" placeholder="Teléfono" disabled />
                <input type="text" id="detail-created-at" placeholder="Creado" disabled />
                <p id="detail-user-msg" class="admin-message admin-col-full"></p>
                <div class="admin-actions-row admin-col-full">
                    <button type="button" class="acsbutton" id="admin-user-detail-close">Cerrar</button>
                    <button type="button" class="acsbutton" id="admin-user-detail-edit">Editar</button>
                    <button type="submit" class="acpbutton" id="admin-user-detail-save" style="display:none;">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>

    <div class="form-modal" id="admin-db-table-modal">
        <div class="form-modal-box success" class="admin-modal-box admin-modal-box-xl">
            <h2 id="admin-db-table-title" class="admin-no-margin">Tabla</h2>
            <p id="admin-db-table-subtitle" class="admin-subtitle">Consulta los registros y edita la fila que necesites.</p>
            <div id="admin-db-table-content" class="admin-scroll-grid"></div>
            <div class="admin-actions-row">
                <button type="button" class="acsbutton" id="admin-db-table-close">Cerrar</button>
            </div>
        </div>
    </div>

    <div class="form-modal" id="admin-db-row-modal">
        <div class="form-modal-box success" class="admin-modal-box admin-modal-box-lg">
            <h2 id="admin-db-row-title" class="admin-no-margin">Editar fila</h2>
            <p id="admin-db-row-subtitle" class="admin-subtitle">Modifica los campos permitidos y guarda los cambios.</p>
            <form id="admin-db-row-form" class="admin-form-stack">
                <div id="admin-db-row-fields" class="admin-fields-grid"></div>
                <p id="admin-db-row-msg" class="admin-message"></p>
                <div class="admin-actions-row">
                    <button type="button" class="acsbutton" id="admin-db-row-cancel">Cancelar</button>
                    <button type="submit" class="acpbutton" id="admin-db-row-save">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>

    <AppModal client:load modalId="admin-user-feedback" />
</Layout>

<script>
    const openFeedbackModal = (type: "success" | "error", title: string, text: string) => {
        window.dispatchEvent(new CustomEvent("app-modal:open", {
            detail: {
                id: "admin-user-feedback",
                config: {
                    kind: "message",
                    type,
                    title,
                    text,
                    buttonText: "Aceptar",
                    showButton: true,
                    showProgress: false,
                    closeOnBackdrop: true,
                    showCloseButton: false,
                },
            },
        }))
    }

    const createUserCard = (user: {
        id: string
        username: string
        nombre: string | null
        apellidos: string | null
        email: string
        rol: string
        hasAvatar: boolean
    }) => {
        const card = document.createElement("div")
        card.className = "admin-user"
        card.dataset.userId = String(user.id)

        const fullName = [user.nombre, user.apellidos].filter(Boolean).join(" ").trim()
        const label = fullName
            ? `${user.username} | ${fullName} | ${user.rol}`
            : `${user.username} | ${user.email} | ${user.rol}`

        card.innerHTML = `
            <img src="${user.hasAvatar ? `/api/auth/avatar/${user.id}` : "/user.png"}" alt="${user.username}" onerror="this.src='/user.png'" />
            <p>${label}</p>
        `

        return card
    }

    const createInfoCard = (text: string) => {
        const card = document.createElement("div")
        card.className = "admin-user"
        card.innerHTML = `<img src="/user.png" alt="info" /><p>${text}</p>`
        return card
    }

    const setupAdminUsers = () => {
        const searchInput = document.getElementById("admin-user-search") as HTMLInputElement | null
        const createButton = document.getElementById("admin-user-create-open") as HTMLButtonElement | null
        const refreshButton = document.getElementById("admin-user-refresh") as HTMLButtonElement | null
        const list = document.getElementById("admin-users-list") as HTMLDivElement | null
        const modal = document.getElementById("admin-create-user-modal") as HTMLDivElement | null
        const form = document.getElementById("admin-create-user-form") as HTMLFormElement | null
        const cancelButton = document.getElementById("admin-create-user-cancel") as HTMLButtonElement | null
        const submitButton = document.getElementById("admin-create-user-submit") as HTMLButtonElement | null
        const msg = document.getElementById("create-user-msg") as HTMLParagraphElement | null
        const detailModal = document.getElementById("admin-user-detail-modal") as HTMLDivElement | null
        const detailForm = document.getElementById("admin-user-detail-form") as HTMLFormElement | null
        const detailClose = document.getElementById("admin-user-detail-close") as HTMLButtonElement | null
        const detailEdit = document.getElementById("admin-user-detail-edit") as HTMLButtonElement | null
        const detailSave = document.getElementById("admin-user-detail-save") as HTMLButtonElement | null
        const detailMsg = document.getElementById("detail-user-msg") as HTMLParagraphElement | null
        const detailUserId = document.getElementById("detail-user-id") as HTMLInputElement | null
        const detailUsername = document.getElementById("detail-username") as HTMLInputElement | null
        const detailRole = document.getElementById("detail-role") as HTMLSelectElement | null
        const detailName = document.getElementById("detail-name") as HTMLInputElement | null
        const detailLastname = document.getElementById("detail-lastname") as HTMLInputElement | null
        const detailEmail = document.getElementById("detail-email") as HTMLInputElement | null
        const detailPhone = document.getElementById("detail-phone") as HTMLInputElement | null
        const detailCreatedAt = document.getElementById("detail-created-at") as HTMLInputElement | null

        if (!searchInput || !createButton || !refreshButton || !list || !modal || !form || !cancelButton || !submitButton || !msg || !detailModal || !detailForm || !detailClose || !detailEdit || !detailSave || !detailMsg || !detailUserId || !detailUsername || !detailRole || !detailName || !detailLastname || !detailEmail || !detailPhone || !detailCreatedAt || list.dataset.initialized === "true") return
        list.dataset.initialized = "true"

        let controller: AbortController | null = null
        let debounceId: number | null = null
        let detailEditMode = false

        const setFormMessage = (text = "", color = "#e74c3c") => {
            msg.textContent = text
            msg.style.display = text ? "block" : "none"
            msg.style.color = color
        }

        const setDetailMessage = (text = "", color = "#e74c3c") => {
            detailMsg.textContent = text
            detailMsg.style.display = text ? "block" : "none"
            detailMsg.style.color = color
        }

        const openCreateModal = () => {
            setFormMessage("")
            form.reset()
            modal.classList.add("active")
        }

        const closeCreateModal = () => {
            modal.classList.remove("active")
            setFormMessage("")
            form.reset()
            submitButton.disabled = false
            submitButton.textContent = "Crear usuario"
        }

        const setDetailEditMode = (enabled: boolean) => {
            detailEditMode = enabled
            ;[
                detailUsername,
                detailRole,
                detailName,
                detailLastname,
                detailEmail,
                detailPhone,
            ].forEach((field) => {
                field.disabled = !enabled
            })
            detailEdit.style.display = enabled ? "none" : "inline-flex"
            detailSave.style.display = enabled ? "inline-flex" : "none"
        }

        const closeDetailModal = () => {
            detailModal.classList.remove("active")
            setDetailMessage("")
            detailForm.reset()
            detailSave.disabled = false
            detailSave.textContent = "Guardar cambios"
            setDetailEditMode(false)
        }

        const formatCreatedAt = (value: string | null) => {
            if (!value) return "-"
            const date = new Date(value)
            if (Number.isNaN(date.getTime())) return value
            return date.toLocaleString("es-ES")
        }

        const loadUserDetail = async (userId: string) => {
            setDetailMessage("")
            setDetailEditMode(false)
            detailSave.disabled = false
            detailSave.textContent = "Guardar cambios"
            detailModal.classList.add("active")

            detailUsername.value = ""
            detailName.value = ""
            detailLastname.value = ""
            detailEmail.value = ""
            detailPhone.value = ""
            detailCreatedAt.value = ""

            try {
                const res = await fetch(`/api/admin/users/${encodeURIComponent(userId)}`)
                const data = await res.json()

                if (!res.ok) {
                    setDetailMessage(data.message || "No se pudo cargar el usuario.")
                    return
                }

                const user = data.user
                detailUserId.value = user.id
                detailUsername.value = user.username || ""
                detailRole.value = user.rol || "cliente"
                detailName.value = user.nombre || ""
                detailLastname.value = user.apellidos || ""
                detailEmail.value = user.email || ""
                detailPhone.value = user.telefono || ""
                detailCreatedAt.value = formatCreatedAt(user.created_at || null)
            } catch {
                setDetailMessage("No se pudo cargar el usuario.")
            }
        }

        const renderUsers = (users: Array<{
            id: string
            username: string
            nombre: string | null
            apellidos: string | null
            email: string
            rol: string
            hasAvatar: boolean
        }>) => {
            list.innerHTML = ""

            if (!users.length) {
                list.appendChild(createInfoCard("No se han encontrado usuarios."))
                return
            }

            users.forEach((user) => {
                const card = createUserCard(user)
                card.style.cursor = "pointer"
                card.addEventListener("click", () => {
                    loadUserDetail(user.id)
                })
                list.appendChild(card)
            })
        }

        const loadUsers = async (query = "") => {
            if (controller) controller.abort()
            controller = new AbortController()

            list.innerHTML = ""
            list.appendChild(createInfoCard("Cargando usuarios..."))

            try {
                const url = new URL("/api/admin/users", window.location.origin)
                if (query.trim()) {
                    url.searchParams.set("q", query.trim())
                }

                const res = await fetch(url.pathname + url.search, {
                    signal: controller.signal,
                })

                const data = await res.json()

                if (!res.ok) {
                    if (res.status === 401 || res.status === 403) {
                        list.innerHTML = ""
                        list.appendChild(createInfoCard("No tienes permisos para ver usuarios."))
                        return
                    }

                    throw new Error(data?.error || "load_users_failed")
                }

                renderUsers(data.users || [])
            } catch (error) {
                if ((error as Error).name === "AbortError") return

                list.innerHTML = ""
                list.appendChild(createInfoCard("No se pudieron cargar los usuarios."))
            }
        }

        searchInput.addEventListener("input", () => {
            if (debounceId) window.clearTimeout(debounceId)
            debounceId = window.setTimeout(() => {
                loadUsers(searchInput.value)
            }, 250)
        })

        refreshButton.addEventListener("click", () => {
            loadUsers(searchInput.value)
        })

        createButton.addEventListener("click", openCreateModal)
        cancelButton.addEventListener("click", closeCreateModal)
        detailClose.addEventListener("click", closeDetailModal)
        detailEdit.addEventListener("click", () => {
            setDetailMessage("")
            setDetailEditMode(true)
        })

        modal.addEventListener("click", (event) => {
            if (event.target === modal) {
                closeCreateModal()
            }
        })

        detailModal.addEventListener("click", (event) => {
            if (event.target === detailModal) {
                closeDetailModal()
            }
        })

        form.addEventListener("submit", async (event) => {
            event.preventDefault()
            setFormMessage("")

            const payload = {
                email: (document.getElementById("create-email") as HTMLInputElement).value.trim(),
                rol: (document.getElementById("create-role") as HTMLSelectElement).value,
                username: (document.getElementById("create-username") as HTMLInputElement).value.trim(),
                nombre: (document.getElementById("create-name") as HTMLInputElement).value.trim(),
                apellidos: (document.getElementById("create-lastname") as HTMLInputElement).value.trim(),
                telefono: (document.getElementById("create-phone") as HTMLInputElement).value.trim(),
            }

            if (!payload.email || !payload.username || !payload.nombre || !payload.apellidos) {
                setFormMessage("Completa todos los campos obligatorios.")
                return
            }

            submitButton.disabled = true
            submitButton.textContent = "Creando..."

            try {
                const res = await fetch("/api/admin/create-user", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                })

                const data = await res.json()

                if (!res.ok) {
                    setFormMessage(data.message || "No se pudo crear el usuario.")
                    submitButton.disabled = false
                    submitButton.textContent = "Crear usuario"
                    return
                }

                closeCreateModal()
                openFeedbackModal(
                    "success",
                    "Usuario creado",
                    "La cuenta se ha creado correctamente y el email con la contraseña temporal ya ha sido enviado."
                )
                loadUsers(searchInput.value)
            } catch {
                setFormMessage("No se pudo crear el usuario.")
                submitButton.disabled = false
                submitButton.textContent = "Crear usuario"
            }
        })

        detailForm.addEventListener("submit", async (event) => {
            event.preventDefault()
            setDetailMessage("")

            const payload = {
                username: detailUsername.value.trim(),
                rol: detailRole.value,
                nombre: detailName.value.trim(),
                apellidos: detailLastname.value.trim(),
                email: detailEmail.value.trim(),
                telefono: detailPhone.value.trim(),
            }

            if (!detailUserId.value || !payload.username || !payload.nombre || !payload.apellidos || !payload.email) {
                setDetailMessage("Completa todos los campos obligatorios.")
                return
            }

            detailSave.disabled = true
            detailSave.textContent = "Guardando..."

            try {
                const res = await fetch(`/api/admin/users/${encodeURIComponent(detailUserId.value)}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                })
                const data = await res.json()

                if (!res.ok) {
                    setDetailMessage(data.message || "No se pudo guardar el usuario.")
                    detailSave.disabled = false
                    detailSave.textContent = "Guardar cambios"
                    return
                }

                setDetailEditMode(false)
                detailSave.disabled = false
                detailSave.textContent = "Guardar cambios"
                setDetailMessage("Usuario actualizado correctamente.", "#2ecc71")
                detailCreatedAt.value = formatCreatedAt(data.user?.created_at || null)
                loadUsers(searchInput.value)
            } catch {
                setDetailMessage("No se pudo guardar el usuario.")
                detailSave.disabled = false
                detailSave.textContent = "Guardar cambios"
            }
        })

        loadUsers()
    }

    const renderDatabaseTemplate = () => `
        <h2>Gestión de Base de datos</h2>
        <div class="admin-section-stack">
            <div class="admin-stats-grid">
                <div class="admin-card admin-card-8">
                    <p class="admin-overline">Usuarios</p>
                    <h3 id="db-stat-users" class="admin-stat-value-md">-</h3>
                    <span class="admin-meta">Registros totales</span>
                </div>
                <div class="admin-card admin-card-8">
                    <p class="admin-overline">Citas</p>
                    <h3 id="db-stat-citas-month" class="admin-stat-value-md">-</h3>
                    <span class="admin-meta">Este mes</span>
                </div>
                <div class="admin-card admin-card-8">
                    <p class="admin-overline">QR activos</p>
                    <h3 id="db-stat-qr-active" class="admin-stat-value-md">-</h3>
                    <span class="admin-meta">Campañas activas</span>
                </div>
                <div class="admin-card admin-card-8">
                    <p class="admin-overline">Ultimo backup</p>
                    <h3 id="db-stat-backup-date" style="margin:0; font-size:20px;">Sin backup</h3>
                    <span id="db-stat-backup-time" class="admin-meta">Todavia no hay copias manuales</span>
                </div>
            </div>

            <div class="admin-split-grid">
                <div class="admin-card admin-card-8">
                    <div class="admin-header-row">
                        <div>
                            <h3 class="admin-title-md">Tablas principales</h3>
                            <p class="admin-caption">Pulsa una tabla para ver sus datos y editar filas</p>
                        </div>
                    </div>

                    <div class="admin-grid-10">
                        <div style="display:grid; grid-template-columns:1.4fr .8fr .8fr .8fr; gap:10px; padding:12px; border-radius:8px; background:var(--secondary); font-size:13px; opacity:.7;">
                            <strong>Tabla</strong>
                            <strong>Estado</strong>
                            <strong>Filas</strong>
                            <strong>Tamaño</strong>
                        </div>
                        <div id="admin-db-tables" class="admin-grid-10">
                            <div style="display:grid; grid-template-columns:1.4fr .8fr .8fr .8fr; gap:10px; padding:12px; border-radius:8px; background:var(--secondary);">
                                <span>Cargando...</span>
                                <span>-</span>
                                <span>-</span>
                                <span>-</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="admin-card admin-card-8">
                    <h3 class="admin-title-block">Acciones rapidas</h3>
                    <p class="admin-copy">Herramientas reales de mantenimiento y exportacion</p>

                    <div class="admin-grid-10">
                        <button class="acpbutton" type="button" id="admin-db-backup">Crear backup manual</button>
                        <button class="acsbutton" type="button" id="admin-db-export-users">Exportar usuarios</button>
                        <button class="acsbutton" type="button" id="admin-db-export-citas">Exportar citas</button>
                        <button class="acsbutton" type="button" id="admin-db-cleanup">Limpiar logs antiguos</button>
                        <button class="acsbutton" type="button" id="admin-db-reindex">Reindexar tablas</button>
                    </div>

                    <div style="margin-top:16px; padding:14px; border-radius:8px; background:var(--secondary);">
                        <p style="margin:0 0 6px; font-size:13px; opacity:.6;">Ultima operacion</p>
                        <strong id="admin-db-operation-title" style="display:block; margin-bottom:4px;">Pendiente de actividad</strong>
                        <span id="admin-db-operation-detail" class="admin-muted">Las acciones que hagas aqui quedaran registradas.</span>
                    </div>
                </div>
            </div>

            <div class="admin-card admin-card-8">
                <div class="admin-header-row">
                    <div>
                        <h3 class="admin-title-md">Actividad reciente</h3>
                        <p class="admin-caption">Historial de mantenimiento y exportaciones del panel</p>
                    </div>
                    <button class="acsbutton" type="button" id="admin-db-history-open">Ver historial</button>
                </div>

                <div id="admin-db-activity" class="admin-grid-10">
                    <div class="admin-surface-row">
                        <strong class="admin-block">Cargando actividad...</strong>
                        <span class="admin-muted">Espera un momento</span>
                    </div>
                </div>
            </div>
        </div>
    `

    const renderServerTemplate = () => `
        <h2>Gestión del servidor</h2>
        <div class="admin-section-stack">
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:12px;">
                <div class="admin-card admin-card-10">
                    <p class="admin-overline">CPU</p>
                    <h3 id="server-cpu-value" class="admin-stat-value-lg">-</h3>
                    <span id="server-cpu-meta" class="admin-meta">Cargando...</span>
                </div>
                <div class="admin-card admin-card-10">
                    <p class="admin-overline">Memoria RAM</p>
                    <h3 id="server-memory-value" class="admin-stat-value-lg">-</h3>
                    <span id="server-memory-meta" class="admin-meta">Cargando...</span>
                </div>
                <div class="admin-card admin-card-10">
                    <p class="admin-overline">Disco</p>
                    <h3 id="server-disk-value" class="admin-stat-value-lg">-</h3>
                    <span id="server-disk-meta" class="admin-meta">Cargando...</span>
                </div>
                <div class="admin-card admin-card-10">
                    <p class="admin-overline">Uptime</p>
                    <h3 id="server-uptime-value" class="admin-stat-value-lg">-</h3>
                    <span class="admin-meta">reinicio más reciente</span>
                </div>
            </div>

            <div class="admin-server-grid">
